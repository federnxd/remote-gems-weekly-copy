{
  "name": "OpenRole",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Job title"
    },
    "category": {
      "type": "string",
      "enum": [
        "engineering",
        "design",
        "content",
        "finance_legal",
        "science",
        "management",
        "media",
        "other"
      ],
      "description": "Role category"
    },
    "target_audience": {
      "type": "string",
      "description": "Who to target on LinkedIn for this role"
    },
    "hashtags": {
      "type": "string",
      "description": "Relevant hashtags for this role"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "priority": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ],
      "default": "medium"
    },
    "openings": {
      "type": "number",
      "description": "Number of open positions available for this role",
      "default": 0
    }
  },
  "required": [
    "title",
    "category"
  ]
}